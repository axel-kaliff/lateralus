#!/usr/bin/bash
# Install Homebrew and packages on first boot or after rebase
# Version-aware: skips if the current image was already set up
set -eoux pipefail

HOMEBREW_PREFIX="/home/linuxbrew/.linuxbrew"
STAMP="/var/lib/lateralus/brew-setup-done"

# Pin installer commit to avoid supply-chain risk from fetching HEAD
BREW_INSTALL_COMMIT="6d5e2670d07961e7985d2079a2f0a484420f3c38"

# Get current image version for stamp comparison
if [ -f /etc/os-release ]; then
    # shellcheck source=/dev/null
    . /etc/os-release
    IMAGE_VERSION="${OSTREE_VERSION:-${VERSION_ID:-unknown}}"
else
    IMAGE_VERSION="unknown"
fi
IMAGE_ID="lateralus-${IMAGE_VERSION}"

# Skip if this exact image version was already set up
if [ -f "$STAMP" ] && [ "$(cat "$STAMP")" = "$IMAGE_ID" ]; then
    echo "Homebrew already set up for ${IMAGE_ID}, skipping."
    exit 0
fi

# Create the linuxbrew user if it doesn't exist
if ! id linuxbrew &>/dev/null; then
    useradd -m -d /home/linuxbrew -s /bin/bash linuxbrew
fi
mkdir -p /home/linuxbrew
chown linuxbrew:linuxbrew /home/linuxbrew

# Install Homebrew if not already present
if [ -x "${HOMEBREW_PREFIX}/bin/brew" ] && su - linuxbrew -c "${HOMEBREW_PREFIX}/bin/brew --version" &>/dev/null; then
    echo "Homebrew is already installed, updating..."
    su - linuxbrew -c "${HOMEBREW_PREFIX}/bin/brew update" || true
else
    echo "Installing Homebrew from network..."
    mkdir -p "${HOMEBREW_PREFIX}"
    chown -R linuxbrew:linuxbrew /home/linuxbrew
    export NONINTERACTIVE=1
    su - linuxbrew -c "export NONINTERACTIVE=1; /usr/bin/bash -c \"\$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/${BREW_INSTALL_COMMIT}/install.sh)\""
fi

# Install packages from Brewfiles (idempotent — skips already-installed)
for brewfile in /usr/share/ublue-os/homebrew/*.Brewfile; do
    if [ -f "$brewfile" ]; then
        tmp_brewfile="/tmp/$(basename "$brewfile")"
        cp "$brewfile" "$tmp_brewfile"
        chown linuxbrew:linuxbrew "$tmp_brewfile"
        echo "Running brew bundle for $(basename "$brewfile")..."
        su - linuxbrew -c "${HOMEBREW_PREFIX}/bin/brew bundle --file=${tmp_brewfile}" || {
            echo "Retrying after fixing ugrep link conflict..."
            su - linuxbrew -c "${HOMEBREW_PREFIX}/bin/brew link --overwrite ugrep" || true
            su - linuxbrew -c "${HOMEBREW_PREFIX}/bin/brew bundle --file=${tmp_brewfile}" || true
        }
        rm -f "$tmp_brewfile"
    fi
done

# Record which image version was set up
mkdir -p "$(dirname "$STAMP")"
echo "$IMAGE_ID" > "$STAMP"

echo "Homebrew setup complete."
