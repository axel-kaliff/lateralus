#!/usr/bin/bash
# Bootstrap Homebrew on first boot or after rebase
# Runs as a system service — installs brew if missing, then ensures packages are installed
set -eoux pipefail

HOMEBREW_PREFIX="/home/linuxbrew/.linuxbrew"

# Check if brew is already installed and working
if [ -x "${HOMEBREW_PREFIX}/bin/brew" ] && su - linuxbrew -c "${HOMEBREW_PREFIX}/bin/brew --version" &>/dev/null; then
    echo "Homebrew is already installed and working."
else
    echo "Installing Homebrew..."

    # Create the linuxbrew user if it doesn't exist
    if ! id linuxbrew &>/dev/null; then
        useradd -m -d /home/linuxbrew linuxbrew
    fi

    mkdir -p "${HOMEBREW_PREFIX}"
    chown -R linuxbrew:linuxbrew /home/linuxbrew

    # Install Homebrew as linuxbrew user
    export NONINTERACTIVE=1
    su - linuxbrew -c 'export NONINTERACTIVE=1; /usr/bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"'
fi

# Install packages from built-in Brewfiles (idempotent — skips already-installed)
for brewfile in /usr/share/ublue-os/homebrew/*.Brewfile; do
    if [ -f "$brewfile" ]; then
        chown linuxbrew:linuxbrew "$brewfile"
        su - linuxbrew -c "${HOMEBREW_PREFIX}/bin/brew bundle --file=${brewfile} --no-lock" || true
    fi
done

echo "Homebrew setup complete."
