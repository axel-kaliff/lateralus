#!/usr/bin/bash
# Install Lateralus GRUB theme to /boot on first boot
# /boot is a separate partition not available during container build
set -eou pipefail

THEME_SRC="/usr/share/lateralus/grub-theme"
THEME_DST="/boot/grub2/themes/lateralus"

if [ ! -d "$THEME_SRC" ]; then
    echo "GRUB theme source not found at ${THEME_SRC}, skipping."
    exit 0
fi

echo "Installing Lateralus GRUB theme..."

mkdir -p "${THEME_DST}"
cp -a "${THEME_SRC}"/* "${THEME_DST}"/

# Configure GRUB to use the theme via user.cfg
# user.cfg is loaded by GRUB and is not subject to ostree 3-way merge
cat > /boot/grub2/user.cfg << 'GRUBEOF'
set theme=($root)/grub2/themes/lateralus/theme.txt
set gfxmode=auto
terminal_output gfxterm
GRUBEOF

echo "GRUB theme installed."
